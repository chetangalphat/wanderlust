<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-lg-8 offset-lg-2">

    <!-- Listing Card -->
    <div class="card listing-card show-card shadow-lg border-0">
      <img
        src="<%= listing.image.url %>"
        class="card-img-top show-img"
        alt="listing_image"
      />

      <div class="card-body p-4">
         <p class="text-muted mb-2">
  Hosted by <b><%= listing.owner ? listing.owner.username : "Host" %></b>
</p>
        <h2 class="fw-bold mb-2">
          <%= listing.title %>
        </h2>

       <p class="text-secondary mb-4">
  <i class="fa-solid fa-location-dot"></i>
  <%= listing.location %>, <%= listing.country %>
</p>
       

        <p class="text-muted mb-3">
          <%= listing.description %>
        </p>

     <h4 class="fw-bold mb-4">
  ₹<%= listing.price.toLocaleString("en-IN") %>
  <span class="fs-6 text-muted fw-normal">night</span>
</h4>

      
        <!-- Buttons -->
     

<% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>

<div class="d-flex gap-2 mt-4">
  <a
    href="/listings/<%= listing._id %>/edit"
    class="btn btn-danger px-4"
  >
    Edit
  </a>

  <form
    method="POST"
    action="/listings/<%= listing._id %>?_method=DELETE"
  >
    <button class="btn btn-dark px-4">
      Delete
    </button>
  </form>
</div>

<% } %>


<% if(currUser) { %>
<!-- Review Form -->
<div class="card border-0 shadow-sm rounded-4 mt-5">

  <div class="card-body p-4">

    <h4 class="fw-bold mb-4">
      ⭐ Leave a Review
    </h4>

    <form
      action="/listings/<%= listing.id %>/reviews"
      method="POST"
      novalidate
      class="needs-validation"
    >

      <div class="mb-4">

        <label
          for="rating"
          class="form-label fw-semibold"
        >
          Rating
        </label>

        <input
          type="range"
          min="1"
          max="5"
          id="rating"
          name="review[rating]"
          class="form-range"
        >

        <div class="d-flex justify-content-between text-muted small">
          <span>Poor</span>
          <span>Excellent</span>
        </div>

      </div>

      <div class="mb-4">

        <label
          for="comment"
          class="form-label fw-semibold"
        >
          Comment
        </label>

        <textarea
          name="review[comment]"
          id="comment"
          rows="4"
          class="form-control rounded-3"
          placeholder="Share your experience..."
          required
        ></textarea>

        <div class="invalid-feedback">
          Please add some comments for review
        </div>

      </div>

      <button class="btn btn-dark px-4 rounded-3">
        Submit Review
      </button>

    </form>

  </div>

</div>

<% } %>

  <!-- All Reviews -->
<div class="mt-5">
  <h4 class="mb-4">All Reviews</h4>
  <div class="row">
    <% for(let review of listing.reviews) { %>
      <div class="col-md-6 mb-4">
        <div class="card review-card p-3 h-100">
          <div class="card-body">
            <h5 class="mb-2">
  <%= review.author ? review.author.username : "Guest" %>
</h5>
            <p class="text-muted">
              <%= review.comment %>
            </p>
            <p>
              Rating:
              <b><%= review.rating %> ★</b>
            </p>
          <% if(currUser && review.author && review.author._id.equals(currUser._id)) { %>

<form
  method="POST"
  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
>
  <button class="btn btn-sm btn-outline-dark">
    Delete
  </button>
</form>

<% } %>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>
  </div>
</div>


