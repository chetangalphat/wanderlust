<% layout("/layouts/boilerplate") %>
<style>
#filters{
  display:flex;
  align-items:center;
  overflow-x:auto;
  padding:1rem 2rem;
  gap:2rem;
  border-bottom:1px solid #e9ecef;
  margin-bottom:2rem;
}

#filters::-webkit-scrollbar{
  display:none;
}

.filter{
  text-align:center;
  opacity:0.7;
  min-width:80px;
  transition:all 0.2s ease;
}

.filter:hover{
  opacity:1;
  cursor:pointer;
  transform:translateY(-2px);
}

.filter i{
  font-size:1.3rem;
  margin-bottom:0.5rem;
}

.filter p{
  font-size:0.85rem;
  margin:0;
}

.tax-toggle{
  border:1px solid #ccc;
  border-radius:1rem;
  padding:0.8rem 1rem;
  margin-left:auto;
  white-space:nowrap;
}
</style>

